{
	"name": "commit-recap",
	"version": "1.0.0",
	"description": "NestJSプロジェクトの構造変化をレポートするCLIツール",
	"type": "module",
	"main": "./dist/index.js",
	"bin": {
		"commit-recap": "./dist/index.js"
	},
	"scripts": {
		"dev": "tsx src/index.ts",
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"keywords": [
		"nestjs",
		"git",
		"report",
		"cli"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@anthropic-ai/sdk": "^0.78.0",
		"chalk": "^5.3.0",
		"commander": "^12.1.0",
		"dotenv": "^17.3.1",
		"ora": "^8.0.1",
		"simple-git": "^3.27.0",
		"ts-morph": "^27.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/node": "^22.13.5",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"tsup": "^8.3.6",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"lint-staged": {
		"*": [
			"biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
		]
	}
}
